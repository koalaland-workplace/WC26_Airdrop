generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  owner
  admin
  moderator
  support
  analyst
}

enum UserStatus {
  active
  banned
  vip
}

model BoardMember {
  id           String         @id @default(cuid())
  telegramId   String         @unique
  username     String
  displayName  String
  role         AdminRole
  requiresTotp Boolean        @default(false)
  totpSecret   String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  kickLedgers  KickLedger[]
  announcements Announcement[]
  audits       AuditLog[]
}

model AdminSession {
  id               String      @id @default(cuid())
  boardMemberId    String
  refreshTokenHash String      @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  rotatedFromId    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  boardMember      BoardMember @relation(fields: [boardMemberId], references: [id], onDelete: Cascade)
}

model AppUser {
  id               String           @id @default(cuid())
  telegramId       String?          @unique
  username         String?
  nationCode       String           @default("VN")
  status           UserStatus       @default(active)
  kick             Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  ledgers          KickLedger[]
  referralsSent    ReferralEvent[]  @relation("ReferralInviter")
  referredByEvents ReferralEvent[]  @relation("ReferralInvitee")
  missions         MissionProgress[]
}

model KickLedger {
  id          String      @id @default(cuid())
  userId       String
  delta        Int
  reason       String
  source       String
  actorId      String?
  createdAt    DateTime   @default(now())
  user         AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor        BoardMember? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model FeatureConfig {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String      @id @default(cuid())
  title       String
  message     String
  target      String      @default("all")
  createdById String?
  createdAt   DateTime    @default(now())
  publishedAt DateTime?
  createdBy   BoardMember? @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model PiqueConversation {
  id            String   @id @default(cuid())
  appUserId     String?
  telegramId    String?
  username      String?
  prompt        String
  reply         String
  sentimentFlag String?  @default("neutral")
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([telegramId])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actorRole  AdminRole?
  action     String
  module     String
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  actor      BoardMember? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([module, action])
}

model ReferralEvent {
  id               String    @id @default(cuid())
  inviterUserId    String
  invitedUserId    String?
  invitedTelegramId String?
  level            Int       @default(1)
  status           String    @default("registered")
  season           String    @default("S1")
  kickAward        Int       @default(0)
  riskScore        Int       @default(0)
  createdAt        DateTime  @default(now())
  inviter          AppUser   @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invited          AppUser?  @relation("ReferralInvitee", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([inviterUserId, createdAt])
  @@index([status, createdAt])
}

model MatchFixture {
  id         String   @id @default(cuid())
  groupCode  String
  homeNation String
  awayNation String
  stadium    String
  city       String?
  kickoffAt  DateTime
  status     String   @default("scheduled")
  homeScore  Int?
  awayScore  Int?
  highlight  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([kickoffAt, status])
  @@index([groupCode])
}

model Mission {
  id         String            @id @default(cuid())
  code       String            @unique
  name       String
  phase      String            @default("Viral Activation")
  category   String            @default("daily")
  rewardKick Int
  isActive   Boolean           @default(true)
  capPerDay  Int?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  progresses MissionProgress[]

  @@index([isActive, category])
}

model MissionProgress {
  id          String   @id @default(cuid())
  missionId   String
  userId      String
  status      String   @default("completed")
  progress    Int      @default(100)
  awardedKick Int      @default(0)
  createdAt   DateTime @default(now())
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([missionId, createdAt])
  @@index([userId, createdAt])
}
